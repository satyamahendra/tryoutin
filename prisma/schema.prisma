// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

enum OrderStatus {
  pending
  accept
  settlement
  deny
  cancel
  expire
  success
}

enum ProductType {
  single
  bundle
}

enum ReportStatus {
  open
  in_review
  waiting_user
  waiting_admin
  resolved
  rejected
}

enum ReportType {
  bug
  billing
  content
  account
  other
}

enum QuestionType {
  multiple_choice
  single_choice   // traditional right/wrong question
  scaled_choice   // "most correct" style question (e.g. TKP), every option has its own point value
  essay           // free-text answer, requires manual grading
}

enum ExamSessionStatus {
  in_progress
  completed
  expired
  abandoned
}

enum ExamPartSessionStatus {
  not_started
  in_progress
  completed
  expired
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String           @id
  name          String
  email         String           @unique
  emailVerified Boolean          @default(false)
  image         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  sessions      Session[]
  accounts      Account[]
  roles         UserRole[]
  orders        Order[]
  permissions   UserPermission[]
  entitlements  Entitlement[]
  reports       Report[]
  report_messages ReportMessage[]

  exam_sessions   ExamSession[]
  graded_answers  UserAnswer[]     @relation("GradedAnswers")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  token      String?  @unique

  @@index([identifier])
  @@map("verification")
}

model Role {
  name        String           @id
  is_active   Boolean          @default(true)

  users       UserRole[]
  permissions RolePermission[]

  @@map("role")
}

model Permission {
  name  String           @id
  is_active   Boolean          @default(true)

  users UserPermission[]
  roles RolePermission[]

  @@map("permission")
}

model UserRole {
  user_id   String
  role_name String
  user      User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role      Role   @relation(fields: [role_name], references: [name], onDelete: Cascade)

  @@id([user_id, role_name])  // composite PK, no need for a separate id
  @@map("user_role")
}

model UserPermission {
  user_id         String
  permission_name String
  user            User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  permission      Permission @relation(fields: [permission_name], references: [name], onDelete: Cascade)

  @@id([user_id, permission_name])  // composite PK
  @@map("user_permission")
}

model RolePermission {
  role_name       String
  permission_name String
  role            Role       @relation(fields: [role_name], references: [name], onDelete: Cascade)
  permission      Permission @relation(fields: [permission_name], references: [name], onDelete: Cascade)

  @@id([role_name, permission_name])  // composite PK
  @@map("role_permission")
}

model Product {
  id          String      @id @default(uuid())
  name        String
  price_alternate   Int @default(0)
  price_actual   Int @default(0)
  type        ProductType @default(single)
  is_active   Boolean     @default(true)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  bundle_items BundleItem[] @relation("bundle_items")
  included_in  BundleItem[] @relation("products_in_bundle")
  entitlements Entitlement[]

  exam Exam?

  @@map("product")
}

model BundleItem {
  id         String @id @default(uuid())
  bundle_id  String
  product_id String

  bundle  Product @relation("bundle_items", fields: [bundle_id], references: [id], onDelete: Cascade)
  product Product @relation("products_in_bundle", fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([bundle_id, product_id])
  @@map("bundle_item")
}

model Order {
  id                  String      @id @default(uuid())
  user_id             String
  midtrans_order_id   String      @unique
  status              OrderStatus @default(pending)
  gross_amount         Int
  paid_at              DateTime?
  created_at           DateTime    @default(now())
  updated_at           DateTime    @updatedAt
  midtrans_request    Json?
  midtrans_response   Json?
  midtrans_token      String?
  midtrans_redirect   String?

  user                User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  entitlements        Entitlement[]
  reports             Report[]

  @@index([user_id])
  @@map("order")
}

model Entitlement {
  id         String    @id @default(uuid())
  user_id    String
  product_id String
  order_id   String
  expires_at DateTime?
  created_at  DateTime  @default(now())

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id])
  order   Order   @relation(fields: [order_id], references: [id])

  exam_sessions ExamSession[]

  @@index([user_id])
  @@index([order_id])
  @@index([user_id, product_id])
  @@map("entitlement")
}

model Report {
  id          String       @id @default(uuid())
  user_id     String
  type        ReportType   @default(other)
  status      ReportStatus @default(open)
  title       String
  description String
  order_id    String?
  resolved_at DateTime?
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  user     User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  order    Order?          @relation(fields: [order_id], references: [id], onDelete: SetNull)
  messages ReportMessage[]

  @@index([user_id])
  @@index([status])
  @@map("report")
}

model ReportMessage {
  id          String   @id @default(uuid())
  report_id   String
  sender_id   String
  message     String
  is_internal Boolean  @default(false)
  read_at     DateTime?
  created_at  DateTime @default(now())

  report  Report @relation(fields: [report_id], references: [id], onDelete: Cascade)
  sender  User   @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([report_id])
  @@index([sender_id])
  @@map("report_message")
}

model Tag {
  id         String   @id @default(uuid())
  name       String   @unique
  created_at DateTime @default(now())

  exams ExamTag[]

  @@map("tag")
}

model ExamTag {
  exam_id String
  tag_id  String

  exam Exam @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([exam_id, tag_id])
  @@map("exam_tag")
}

model Exam {
  id               String   @id @default(uuid())
  product_id       String?  @unique   // links to the purchasable Product, nullable for free/demo exams
  category         String   // "CPNS", "BUMN", "UTBK", etc.
  title            String
  description      String?
  duration_minutes Int?     // total exam duration, null if timing is fully per-part (see ExamPart)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  product  Product?     @relation(fields: [product_id], references: [id])
  parts    ExamPart[]
  sessions ExamSession[]
  tags     ExamTag[]

  @@map("exam")
}

model ExamPart {
  id               String   @id @default(uuid())
  exam_id          String
  name             String   // "Matematika", "TWK", "TIU", "TKP", "Ekonomi", etc.
  order_index      Int      @default(0)
  duration_minutes Int?     // set this if the part has its own timer (CPNS-style sequential sections)
  passing_score    Float?   // optional passing grade (e.g. TWK ambang batas)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  exam          Exam              @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  questions     Question[]
  session_parts ExamSessionPart[]

  @@index([exam_id])
  @@map("exam_part")
}

model Question {
  id                    String       @id @default(uuid())
  part_id               String
  type                  QuestionType @default(single_choice)
  question_text         String
  question_image String?      // base64-encoded image for the question stem, nullable
  explanation           String?      // shown during review/discussion
  order_index           Int          @default(0)
  created_at            DateTime     @default(now())
  updated_at            DateTime     @updatedAt

  part    ExamPart         @relation(fields: [part_id], references: [id], onDelete: Cascade)
  options QuestionOption[]
  answers UserAnswer[]

  @@index([part_id])
  @@map("question")
}

model QuestionOption {
  id                  String  @id @default(uuid())
  question_id         String
  option_text         String?
  option_image String? // base64-encoded image for the option, nullable
  score               Int     @default(0) // points awarded if this option is picked
  is_correct          Boolean @default(false) // convenience flag for single_choice UI/review, ignored for scaled_choice
  order_index         Int     @default(0)

  question Question     @relation(fields: [question_id], references: [id], onDelete: Cascade)
  answers  UserAnswer[]

  @@index([question_id])
  @@map("question_option")
}

model ExamSession {
  id             String            @id @default(uuid())
  user_id        String
  exam_id        String
  entitlement_id String?           // proof of purchase this session was started under
  status         ExamSessionStatus @default(in_progress)
  started_at     DateTime          @default(now())
  ends_at        DateTime?         // started_at + exam.duration_minutes, computed at session creation
  submitted_at   DateTime?
  total_score    Float?
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt

  user          User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  exam          Exam              @relation(fields: [exam_id], references: [id])
  entitlement   Entitlement?      @relation(fields: [entitlement_id], references: [id])
  answers       UserAnswer[]
  part_sessions ExamSessionPart[]

  @@index([user_id])
  @@index([exam_id])
  @@index([user_id, status]) // fast lookup of a user's "active" session
  @@map("exam_session")
}

model ExamSessionPart {
  id           String                @id @default(uuid())
  session_id   String
  part_id      String
  status       ExamPartSessionStatus @default(not_started)
  started_at   DateTime?
  ends_at      DateTime?
  submitted_at DateTime?

  session ExamSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  part    ExamPart    @relation(fields: [part_id], references: [id])

  @@unique([session_id, part_id])
  @@map("exam_session_part")
}

model UserAnswer {
  id             String    @id @default(uuid())
  session_id     String
  question_id    String
  option_id      String?   // set for single_choice / scaled_choice, null for essay
  answer_text    String?   // set for essay, null for single_choice / scaled_choice
  score_awarded  Float?    // auto-filled on submit for MC/scaled; null until manually graded for essay
  is_graded      Boolean   @default(true) // false for essay until an admin/reviewer scores it
  graded_by      String?   // user_id of the admin/reviewer who graded the essay
  graded_at      DateTime?
  is_flagged     Boolean   @default(false) // "mark for review" during the exam
  answered_at    DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  session  ExamSession     @relation(fields: [session_id], references: [id], onDelete: Cascade)
  question Question        @relation(fields: [question_id], references: [id], onDelete: Cascade)
  option   QuestionOption? @relation(fields: [option_id], references: [id])
  grader   User?           @relation("GradedAnswers", fields: [graded_by], references: [id])

  @@unique([session_id, question_id]) // one answer per question per session, upsert on change
  @@index([is_graded]) // fast lookup of "essays pending review"
  @@map("user_answer")
}
